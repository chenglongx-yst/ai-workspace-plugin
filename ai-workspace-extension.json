{
  "$schema": "../../schemas/aion-extension-v1.json",
  "name": "c-drive-cleaner",
  "displayName": "C盘垃圾回收大师",
  "version": "0.3.1",
  "description": "C盘垃圾扫描与安全/深度清理（对齐设计稿视觉）。",
  "author": "AI-Workspace Contributors",
  "icon": "assets/icon.svg",
  "permissions": {
    "storage": true,
    "network": true,
    "shell": true
  },
  "lifecycle": {
    "onInstall": "scripts/onInstall.js",
    "onActivate": "scripts/activate.js",
    "onDeactivate": "scripts/deactivate.js",
    "timeoutMs": 300000
  },
  "sidecar": {
    "command": "@aiw/node",
    "args": ["scripts/sidecar.js"],
    "health": {
      "host": "127.0.0.1",
      "port": 18765,
      "path": "/api/health",
      "timeoutMs": 20000,
      "intervalMs": 400
    },
    "stopTimeoutMs": 5000
  },
  "contributes": {
    "productCenterApps": "$file:contributes/product-center-apps.json"
  }
}
